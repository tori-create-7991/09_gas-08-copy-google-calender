/**
 * カレンダー同期スクリプト - 設定ファイル
 *
 * このファイルで同期の設定を行います。
 */

/**
 * 設定を取得する
 * @returns {Object} 設定オブジェクト
 */
function getConfig() {
  return {
    // ===== 必須設定 =====

    // コピー元カレンダーのID（共有カレンダーなど）
    // カレンダーの設定から「カレンダーの統合」→「カレンダーID」で確認できます
    SOURCE_CALENDAR_ID: 'ここにコピー元カレンダーIDを入力',

    // コピー先カレンダーのID
    // 'primary' を指定するとメインカレンダーにコピーされます
    DESTINATION_CALENDAR_ID: 'ここにコピー先カレンダーIDを入力',

    // ===== オプション設定 =====

    // 同期する期間（今日から何日前〜何日後までを同期するか）
    DAYS_BEFORE: 7,   // 過去7日分
    DAYS_AFTER: 30,   // 未来30日分

    // コピーした予定のタイトル
    // 'BUSY' や '予定あり' など、元のタイトルを隠したい場合に設定
    // 空文字 '' にすると元のタイトルをそのまま使用
    COPIED_EVENT_TITLE: '予定あり',

    // コピーした予定の説明文に追加するプレフィックス
    // 同期元を識別するために使用
    SYNC_TAG: '[CalendarSync]',

    // コピーした予定の色（1-11 または null で元の色を使用）
    // 1:ラベンダー, 2:セージ, 3:ブドウ, 4:フラミンゴ, 5:バナナ
    // 6:ミカン, 7:ピーコック, 8:グラファイト, 9:ブルーベリー, 10:バジル, 11:トマト
    EVENT_COLOR: 8,  // グラファイト（グレー）

    // 終日イベントもコピーするか
    COPY_ALL_DAY_EVENTS: true,

    // プライベート設定の予定もコピーするか（詳細を見れる場合のみ）
    COPY_PRIVATE_EVENTS: true,

    // コピー先の予定を「予定あり」として表示するか
    // true: 他の人からは「予定あり」と見える
    // false: 予定の詳細が見える（権限による）
    SHOW_AS_BUSY: true,

    // 元の予定へのリンクを説明文に含めるか
    INCLUDE_ORIGINAL_LINK: false,

    // デバッグモード（ログを詳細に出力）
    DEBUG_MODE: false
  };
}
